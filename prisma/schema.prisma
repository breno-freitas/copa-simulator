// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum TipoTorneio {
  LIGA
  COPA
}

model Torneio {
  id               String @id @default(uuid())
  nome             String
  tipo             TipoTorneio
  jogosPorFase     Int    @default(1)
  times            Time[]
  jogos            Jogo[]
  fases            Fase[]
  slug             String @unique
  maximumAttendees Int
}

model Time {
  id         String  @id @default(uuid())
  nome       String
  vitorias   Int     @default(0)
  derrotas   Int     @default(0)
  empates    Int     @default(0)
  golsPro    Int     @default(0)
  golsContra Int     @default(0)
  torneioId  String
  torneio    Torneio @relation(fields: [torneioId], references: [id])
}

model Jogo {
  id         String  @id @default(uuid())
  torneioId  String
  partidaId  String?
  rodada     Int?
  faseId     String
  timeCasaId String
  timeForaId String
  golsCasa   Int     @default(0)
  golsFora   Int     @default(0)
  parId      String?
  torneio    Torneio @relation(fields: [torneioId], references: [id])
  fase       Fase    @relation(fields: [faseId], references: [id])
  vencedorId String?
}

model Fase {
  id        String  @id @default(uuid())
  torneioId String
  nome      String
  numero    Int
  jogos     Jogo[]
  torneio   Torneio @relation(fields: [torneioId], references: [id])
}
